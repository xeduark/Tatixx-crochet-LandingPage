---
interface Props {
  badge?: string;
  badgeColor?: string;
  title: string;
  subtitle?: string;
}
const { badge, badgeColor = 'bg-purple-100 text-purple-700', title, subtitle } = Astro.props;
---
<div class="text-center mb-14">
  {badge && (
    <span class:list={['inline-block px-4 py-1 rounded-full text-sm font-fredoka font-semibold mb-3', badgeColor]}>
      {badge}
    </span>
  )}
  <h2 class="font-fredoka font-bold text-4xl sm:text-5xl text-slate-800 section-title">{title}</h2>
  {subtitle && <p class="text-slate-600 mt-6 max-w-2xl mx-auto">{subtitle}</p>}
</div>