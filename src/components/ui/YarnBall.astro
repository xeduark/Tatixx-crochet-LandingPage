---
interface Props {
  variant?: 'yarn-ball' | 'yarn-ball-2' | 'yarn-ball-3' | 'yarn-ball-4';
  size?: string;
  class?: string;
  style?: string;
  children?: any;
}
const { variant = 'yarn-ball', size = 'w-10 h-10', class: className = '', style, children } = Astro.props;
---
<div class:list={[variant, 'rounded-full', size, className]} style={style}>
  {children}
</div>