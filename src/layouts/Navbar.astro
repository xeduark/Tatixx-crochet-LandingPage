---
import navLinks from '../data/nav.json';
import YarnBall from '../components/ui/YarnBall.astro';
import MobileMenu from './MobileMenu.astro';
---
<header class="fixed top-0 inset-x-0 z-50 backdrop-blur-lg bg-white/70 border-b-2 border-pink-200">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
    <a href="#inicio" class="flex items-center gap-2 group">
      <div class="relative w-10 h-10">
        <YarnBall size="w-full h-full" />
        <div class="absolute inset-1 rounded-full border-2 border-dashed border-white/70"></div>
      </div>
      <div class="leading-tight">
        <span class="font-pacifico text-2xl yarn-text">Taty Crochet</span>
        <span class="block text-[10px] text-pink-500 font-semibold tracking-wider">· tejiendo historias ·</span>
      </div>
    </a>

    <ul class="hidden md:flex items-center gap-8 font-fredoka font-semibold text-slate-700">
      {navLinks.map(link => (
        <li><a href={link.href} class="nav-link">{link.label}</a></li>
      ))}
      <li><a href="#newsletter" class="btn-primary text-white px-5 py-2 rounded-full">Suscríbete</a></li>
    </ul>

    <button id="menuBtn" class="md:hidden p-2 rounded-full bg-pink-100 text-pink-600" aria-label="Menú">
      <i data-lucide="menu" class="w-6 h-6"></i>
    </button>
  </nav>

  <MobileMenu links={navLinks} />
</header>